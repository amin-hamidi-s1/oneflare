# Cloudflare Credentials
# Copy this file to .env.local and populate with your values.
# Never commit .env.local to source control.

# Found at: dash.cloudflare.com → My Profile → API Tokens
CLOUDFLARE_API_TOKEN=

# Found at: dash.cloudflare.com → select your account → right sidebar
CLOUDFLARE_ACCOUNT_ID=

# Found at: dash.cloudflare.com → select your zone → right sidebar
CLOUDFLARE_ZONE_ID=

# Your domain (e.g. novamind.ai)
CLOUDFLARE_DOMAIN=

# Gateway DoH URL for DNS tunneling scenario — location-specific, has a hex subdomain.
# Found at: one.dash.cloudflare.com → Networks → Resolvers & Proxies → DNS locations
#           → [your location] → Edit → Setup instructions → DNS over HTTPS
# Format:   https://<hex-id>.cloudflare-gateway.com/dns-query
# NOTE: do NOT use your team name — that URL resolves DNS but does not log to Gateway.
CF_GATEWAY_DOH_URL=
